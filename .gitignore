# Dependencies
node_modules/
**/node_modules/
backend/node_modules/
frontend/node_modules/
# Python cache
__pycache__/
*.py[cod]
# Environment files
.env
.env.*
# Database files (real data lives in backend/info.db — never committed)
*.db
*.sqlite
