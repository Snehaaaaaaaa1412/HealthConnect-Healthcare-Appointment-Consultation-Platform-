# ─────────────────────────────────────────────────────────────
# HealthConnect — Environment Variables Template
#
# This file is committed to Git as a documentation template.
# Copy it to .env and replace placeholder values with real secrets.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
DB_PATH=./info.db

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Authentication ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate_a_strong_random_secret>
JWT_EXPIRES_IN=7d

# ── Admin Credentials ────────────────────────────────────────
ADMIN_USERNAME=<your_admin_username>
ADMIN_PASSWORD=<your_strong_admin_password>

# ── OTP ──────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Email / SMTP ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your_gmail@gmail.com>
EMAIL_APP_PASSWORD=<your_gmail_app_password>
EMAIL_FROM_NAME=HealthConnect

# ── CORS / Frontend ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── External Services ─────────────────────────────────────────
FLASK_OCR_URL=http://localhost:5001
OLLAMA_URL=http://localhost:11434
